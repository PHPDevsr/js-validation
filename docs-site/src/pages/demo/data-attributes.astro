---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const demoBase = base + '/demo/';
const version = import.meta.env.PUBLIC_APP_VERSION;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>data-rule-* attributes Demo – js-validation</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f8f9fa; color: #1a1a1a; padding: 2rem 1rem; }
      .container { max-width: 640px; margin: 0 auto; }
      .back { display: inline-flex; align-items: center; gap: 0.35rem; color: #0d6efd; text-decoration: none; font-size: 0.9rem; margin-bottom: 1.5rem; }
      .back:hover { text-decoration: underline; }
      h1 { font-size: 1.6rem; margin-bottom: 0.25rem; }
      .desc { color: #555; font-size: 0.95rem; margin-bottom: 2rem; }
      .card { background: #fff; border: 1px solid #dee2e6; border-radius: 8px; padding: 1.75rem; }
      .form-group { margin-bottom: 1.25rem; }
      .form-group label { display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 0.35rem; }
      .form-group input { width: 100%; padding: 0.55rem 0.75rem; border: 1px solid #ced4da; border-radius: 6px; font-size: 0.95rem; outline: none; transition: border-color 0.15s, box-shadow 0.15s; }
      .form-group input:focus { border-color: #86b7fe; box-shadow: 0 0 0 3px rgba(13,110,253,0.15); }
      .form-group input.is-invalid { border-color: #dc3545; }
      .invalid-feedback { display: block; color: #dc3545; font-size: 0.82rem; margin-top: 0.35rem; }
      .hint { font-size: 0.8rem; color: #888; margin-top: 0.25rem; font-family: monospace; }
      .btn { display: inline-flex; align-items: center; margin-top: 0.5rem; padding: 0.6rem 1.5rem; background: #0d6efd; color: #fff; border: none; border-radius: 6px; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: background 0.15s, box-shadow 0.15s; box-shadow: 0 1px 4px rgba(13,110,253,0.25); }
      .btn:hover { background: #0b5ed7; box-shadow: 0 3px 8px rgba(13,110,253,0.3); }
      .btn:active { background: #0a58ca; }
      .alert { margin-top: 1.25rem; padding: 0.75rem 1rem; border-radius: 6px; font-size: 0.9rem; font-weight: 500; }
      .alert-success { background: #d1e7dd; color: #0a3622; border: 1px solid #a3cfbb; }
      code { background: #f4f4f5; padding: 0.1em 0.35em; border-radius: 3px; font-size: 0.88em; }
    </style>
  </head>
  <body>
    <div class="container">
      <a class="back" href={`${demoBase}/`}>← All demos</a>
      <h1><code>data-rule-*</code> attributes</h1>
      <p class="desc">
        Rules and messages can be declared directly in HTML using
        <code>data-rule-{rule}="value"</code> and <code>data-msg-{rule}="message"</code> attributes —
        no JavaScript configuration needed.
      </p>

      <div class="card">
        <form id="demo-form" novalidate>
          <div class="form-group">
            <label for="username">Username</label>
            <input id="username" name="username" type="text" placeholder="e.g. john_doe"
              data-rule-required="true"
              data-rule-minlength="3"
              data-rule-maxlength="20"
              data-msg-required="Username is required."
              data-msg-minlength="At least 3 characters please."
              data-msg-maxlength="No more than 20 characters." />
            <span class="hint">data-rule-required data-rule-minlength="3" data-rule-maxlength="20"</span>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input id="email" name="email" type="text" placeholder="user@example.com"
              data-rule-required="true"
              data-rule-email="true"
              data-msg-required="Email is required."
              data-msg-email="Enter a valid email (e.g. user@domain.com)." />
            <span class="hint">data-rule-required data-rule-email="true"</span>
          </div>
          <div class="form-group">
            <label for="zip">ZIP / Postal code</label>
            <input id="zip" name="zip" type="text" placeholder="e.g. 12345"
              data-rule-required="true"
              data-rule-numeric="true"
              data-rule-minlength="5"
              data-rule-maxlength="5"
              data-msg-numeric="Postal code must contain only digits."
              data-msg-minlength="Must be exactly 5 digits."
              data-msg-maxlength="Must be exactly 5 digits." />
            <span class="hint">data-rule-numeric="true" data-rule-minlength="5" data-rule-maxlength="5"</span>
          </div>
          <button class="btn" type="submit">Submit</button>
        </form>
        <div id="status"></div>
      </div>
    </div>

    <script is:inline src={`https://cdn.jsdelivr.net/npm/@phpdevsr/js-validation@${version}/dist/js-validation.min.js?v=${version}`}></script>
    <script>
      jsValidation.default('#demo-form').submit(function () {
        const el = document.getElementById('status');
        el.innerHTML = '<div class="alert alert-success">✓ All fields valid!</div>';
      });
    </script>
  </body>
</html>
